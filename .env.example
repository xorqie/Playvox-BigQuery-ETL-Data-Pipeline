# Copy this file to `.env` and fill in your own values.
# Never commit your actual `.env` file - it is already excluded via .gitignore.

# --- Playvox ---
# Your Playvox account's API host, e.g. "yourcompany.playvox.eu" or "yourcompany.playvox.com"
PLAYVOX_DOMAIN=your-account.playvox.eu
# Generate this from Playvox: Settings -> API. Format is "key_id:secret"
PLAYVOX_API_KEY=your-playvox-api-key

# --- Google BigQuery ---
BQ_PROJECT_ID=your-gcp-project-id
BQ_DATASET_ID=playvox

# Table name overrides (optional - sensible defaults are used if omitted)
BQ_USERS_TABLE=users
BQ_TEAMS_TABLE=teams
BQ_ROLES_TABLE=roles
BQ_INTERACTIONS_TABLE=interactions
BQ_SCORECARDS_TABLE=scorecards
BQ_CALIBRATIONS_TABLE=calibrations
BQ_EVALUATIONS_TABLE=evaluations
BQ_COACHINGS_TABLE=coachings

# Path to your GCP service account JSON key file (needs BigQuery Data Editor
# and BigQuery Job User roles at minimum)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json

# How many days back the incremental pipelines (users, teams, roles,
# coachings, evaluations) look when syncing
INCREMENTAL_WINDOW_DAYS=3
